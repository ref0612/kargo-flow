{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm ci --prefer-offline",
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "src/**/*.ts": {
      "runtime": "nodejs20.x",
      "maxDuration": 60,
      "memory": 3008
    }
  },
  "headers": [
    {
      "source": "/dist/public/(.*)",
      "headers": [
        {
          "key": "cache-control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(js|css|woff|woff2|png|jpg|jpeg|gif|svg|ico|webp)",
      "headers": [
        {
          "key": "cache-control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "cache-control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
